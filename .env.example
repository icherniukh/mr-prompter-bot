TELEGRAM_BOT_TOKEN=

# Fernet encryption key for user API keys stored in the database.
# Required on first run only — it is written to data/secret.key (mode 0400)
# automatically, after which this env var is ignored.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# The host's shared OpenRouter key used to process each user's free images.
# Leave blank to disable the free tier (users must add their own key first).
HOST_OPENROUTER_KEY=

# How many images a user may process on the host key before bringing their own.
FREE_TIER_LIMIT=25

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Curated shortlist of OpenRouter models — must be image-OUTPUT (editing) models.
# Current candidates under evaluation for watermark removal quality (see config.py).
MODEL_SHORTLIST=google/gemini-3.1-flash-image-preview,openai/gpt-5.4-image-2,x-ai/grok-imagine-image-quality,black-forest-labs/flux.2-klein-4b,sourceful/riverflow-v2-fast,bytedance-seed/seedream-4.5
DEFAULT_MODEL=google/gemini-3.1-flash-image-preview

# Per-image processing timeout (seconds).
PROCESS_TIMEOUT=90
